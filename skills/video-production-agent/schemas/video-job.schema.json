{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hospitality-os.local/schemas/video-job.schema.json",
  "title": "Hospitality OS Video Job",
  "type": "object",
  "additionalProperties": false,
  "required": ["client","client_type","campaign_name","objective","audience","message","language","channel","format","cta","approval_owner","status"],
  "properties": {
    "client": {"type":"string","minLength":2},
    "client_type": {"type":"string","enum":["restaurant","hotel","beach_club","catering","event_venue","tourist_experience","other"]},
    "campaign_name": {"type":"string","minLength":3},
    "objective": {"type":"string","enum":["reservations","catering","private_events","tourist_awareness","guest_communication","brand","staff_training","customer_recovery","demo_sales","other"]},
    "audience": {"type":"string","minLength":3},
    "message": {"type":"string","minLength":3},
    "verified_facts": {"type":"array","items":{"type":"string"}},
    "language": {"type":"string","enum":["EN","PAP","NL","ES","PT","FR"]},
    "channel": {"type":"array","minItems":1,"items":{"type":"string","enum":["Instagram","TikTok","WhatsApp","Website","YouTube","Email","Staff Training","Other"]}},
    "format": {"type":"string","enum":["9:16","1:1","16:9"]},
    "duration_seconds": {"type":"integer","minimum":5,"maximum":600},
    "avatar_name": {"type":["string","null"]},
    "voice_name": {"type":["string","null"]},
    "identity_authorized": {"type":"boolean","default":false},
    "cta": {"type":"string","minLength":2},
    "destination_url": {"type":["string","null"],"format":"uri"},
    "approval_owner": {"type":"string","minLength":2},
    "status": {"type":"string","enum":["Discovery Needed","Brief Ready","Script Draft","Internal Review","Client Approval","In Production","Quality Review","Scheduled","Published","Measured","Archived"]},
    "due_date": {"type":["string","null"],"format":"date"},
    "publish_date": {"type":["string","null"],"format":"date"},
    "script_version": {"type":"string","default":"v0.1"},
    "draft_video_url": {"type":["string","null"],"format":"uri"},
    "published_url": {"type":["string","null"],"format":"uri"},
    "tracking_id": {"type":["string","null"]},
    "metrics": {
      "type":"object",
      "additionalProperties":false,
      "properties": {
        "views":{"type":"integer","minimum":0},
        "completion_rate":{"type":"number","minimum":0,"maximum":1},
        "clicks":{"type":"integer","minimum":0},
        "qualified_leads":{"type":"integer","minimum":0},
        "bookings":{"type":"integer","minimum":0},
        "attributed_revenue":{"type":"number","minimum":0}
      }
    }
  }
}
